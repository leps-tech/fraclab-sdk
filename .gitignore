# Ignore everything by default
*

# Keep gitignore itself
!.gitignore

# Keep SDK source code
!src/
!src/**

# Exclude generated Python cache under src
src/**/__pycache__/
src/**/*.pyc

# Keep tests
!tests/
!tests/**

# Exclude generated Python cache under tests
tests/**/__pycache__/
tests/**/*.pyc

# Keep package/release metadata docs
!pyproject.toml
!poetry.lock
!README.md
!AI_GUIDE.md
!llms.txt
!CHANGELOG.md
!mkdocs.yml
!docs/
!docs/**

# Keep GitHub Actions workflow for automated PyPI publish
!.github/
!.github/workflows/
!.github/workflows/**

# Keep release helper script
!scripts/
!scripts/release.sh
